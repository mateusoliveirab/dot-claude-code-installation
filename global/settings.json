{
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__evaluate_script",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__click",
      "mcp__chrome-devtools__fill",
      "mcp__chrome-devtools__take_screenshot",
      "mcp__chrome-devtools__emulate",
      "mcp__chrome-devtools__resize_page",
      "mcp__chrome-devtools__wait_for",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__new_page",
      "mcp__shadcn-ui__get_component",
      "Bash(npm run lint:*)",
      "Bash(npx eslint:*)",
      "Bash(pkill:*)"
    ],
    "defaultMode": "default",
    "alwaysAllow": [
      {
        "tool": "Read",
        "pathPattern": "src/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "app/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "components/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "lib/**/*"
      },
      {
        "tool": "Read",
        "pathPattern": "*.md"
      },
      {
        "tool": "Read",
        "pathPattern": "*.json"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.ts"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.tsx"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.js"
      },
      {
        "tool": "Grep",
        "pathPattern": "**/*.jsx"
      },
      {
        "tool": "Glob",
        "pathPattern": "**/*"
      },
      {
        "tool": "Bash",
        "prompt": "run linting"
      },
      {
        "tool": "Bash",
        "prompt": "run type checking"
      },
      {
        "tool": "Bash",
        "prompt": "run tests"
      },
      {
        "tool": "Bash",
        "prompt": "check git status"
      },
      {
        "tool": "Bash",
        "prompt": "show git diff"
      },
      {
        "tool": "Bash",
        "prompt": "show git log"
      }
    ],
    "alwaysDeny": [
      {
        "tool": "Bash",
        "prompt": "force delete files or directories"
      },
      {
        "tool": "Bash",
        "prompt": "force push to git"
      },
      {
        "tool": "Write",
        "pathPattern": ".env"
      },
      {
        "tool": "Write",
        "pathPattern": ".env.*"
      },
      {
        "tool": "Write",
        "pathPattern": "**/credentials.json"
      },
      {
        "tool": "Write",
        "pathPattern": "**/secrets.json"
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash $HOME/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "promptSuggestionEnabled": false,
  "voiceEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  }
}